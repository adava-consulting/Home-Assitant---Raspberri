# Copy this file to `.env` in the same directory if you want to override
# the default voice service settings.

# openWakeWord
WAKE_WORD_MODEL=hey_jarvis
# Lower than the upstream default (0.5) to reduce false rejects in this room.
WAKE_WORD_THRESHOLD=0.35
WAKE_WORD_TRIGGER_LEVEL=1
WAKE_WORD_REFRACTORY_SECONDS=1.0

# Whisper / faster-whisper
WHISPER_MODEL=base-int8
WHISPER_LANGUAGE=en
# Smaller beam sizes decode faster on CPU. `1` is a good low-latency default
# for short home automation commands.
WHISPER_BEAM_SIZE=1
# Raspberry Pi 4 typically benefits from using all four CPU cores here.
WHISPER_CPU_THREADS=4
# Bias transcription toward common home-automation phrases used in this setup.
WHISPER_INITIAL_PROMPT=Turn on the lights. Turn off the lights. Turn all lights on. Turn all lights off. Turn on the room lights. Turn off the room lights. Turn on the studio lights. Turn off the studio lights. Set the studio lights to blue. Set the studio lights to 50 percent brightness.
# Trim speech segments more aggressively so the transcript returns sooner after
# you finish speaking.
WHISPER_VAD_MIN_SPEECH_MS=200
WHISPER_VAD_MIN_SILENCE_MS=700

# Piper
PIPER_VOICE=en_US-lessac-medium
