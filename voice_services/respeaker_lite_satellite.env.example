# Copy this file to `respeaker_lite_satellite.env` when you are ready to use the
# ReSpeaker Lite USB microphone on the Raspberry Pi host.

SATELLITE_NAME=respeaker-lite
SATELLITE_URI=tcp://0.0.0.0:10700

# Path where the official wyoming-satellite repository is installed on the Pi host.
WYOMING_SATELLITE_DIR=/opt/wyoming-satellite

# openWakeWord is optional, but recommended for hands-free usage.
WAKE_URI=tcp://127.0.0.1:10400
WAKE_WORD_NAME=hey_jarvis
# Match openWakeWord's refractory window so the host satellite does not accept
# a second wake event while the first command is still winding down.
WAKE_REFRACTORY_SECONDS=6

# Device hints are matched case-insensitively against `arecord -L` / `aplay -L`.
# The wrapper prefers `plughw:` devices, per the official wyoming-satellite docs.
MIC_DEVICE_HINT="ReSpeaker Lite"
# Set to "Headphones" if you want feedback/TTS on the Raspberry 3.5mm jack.
SND_DEVICE_HINT="ReSpeaker Lite"

# Audio processing. These mirror Wyoming satellite settings documented by Home Assistant.
MIC_AUTO_GAIN=15
MIC_NOISE_SUPPRESSION=0
MIC_VOLUME_MULTIPLIER=4.0
MIC_CAPTURE_CHANNELS=2
MIC_CHANNEL_INDEX=
# If you play the wake beep through headphones, 0.0 avoids clipping the start
# of the spoken command.
MIC_SECONDS_TO_MUTE_AFTER_AWAKE_WAV=0.0
SND_VOLUME_MULTIPLIER=2.5
# Optional ALSA mixer configuration for the playback device.
# This is especially useful when the Raspberry 3.5mm jack is too quiet to hear
# the wake confirmation beep.
SND_MIXER_CARD=Headphones
SND_MIXER_CONTROL=PCM
SND_MIXER_LEVEL=100%

# Optional satellite sounds. Leave blank to disable.
# Example for a listening beep:
# SATELLITE_AWAKE_WAV=/home/lucas/ha-command-bridge/voice_services/sounds/listening.wav
SATELLITE_AWAKE_WAV=
SATELLITE_DONE_WAV=
SATELLITE_TIMER_FINISHED_WAV=
# Optional event hooks and debug log.
SATELLITE_EVENT_LOG_FILE=
SATELLITE_ON_DETECTION_COMMAND=
SATELLITE_ON_STREAMING_START_COMMAND=
SATELLITE_ON_STREAMING_STOP_COMMAND=
SATELLITE_ON_TRANSCRIPT_COMMAND=
SATELLITE_ON_STT_START_COMMAND=
SATELLITE_ON_STT_STOP_COMMAND=
SATELLITE_ON_ERROR_COMMAND=
SATELLITE_DEBUG_RECORDING_DIR=
SATELLITE_STREAMING_TIMEOUT_SECONDS=8
SATELLITE_WATCHDOG_STATE_FILE=/tmp/wyoming-satellite-watchdog.state
# If the wake word fires and the user never starts speaking, force the satellite
# back to idle after this many seconds.
SATELLITE_NO_SPEECH_TIMEOUT_SECONDS=7
SATELLITE_NO_SPEECH_STATE_FILE=/tmp/wyoming-satellite-no-speech.state
# If STT ends but no transcript ever comes back from Whisper/Home Assistant,
# force a quick recovery instead of waiting for a much longer disconnect path.
SATELLITE_TRANSCRIPT_TIMEOUT_SECONDS=12
SATELLITE_TRANSCRIPT_TIMEOUT_STATE_FILE=/tmp/wyoming-satellite-transcript.state
# If the satellite self-triggers right after a successful command, restart it
# quickly instead of letting the false second wake linger.
SATELLITE_POST_TRANSCRIPT_COOLDOWN_SECONDS=6
SATELLITE_POST_TRANSCRIPT_STATE_FILE=/tmp/wyoming-satellite-post-transcript.state
# Optional explicit entity id to reset on Home Assistant when a no-speech timeout happens.
# Disabled by default because some Home Assistant setups try to synthesize an
# empty reply and end up disconnecting the satellite instead.
SATELLITE_FORCE_ASSIST_IDLE_ON_RECOVERY=0
ASSIST_SATELLITE_ENTITY_ID=assist_satellite.respeaker_lite

# Startup behavior
SATELLITE_WAIT_FOR_DEVICE_SECONDS=5
SATELLITE_DEBUG=0
