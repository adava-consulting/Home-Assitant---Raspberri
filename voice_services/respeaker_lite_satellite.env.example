# Copy this file to `respeaker_lite_satellite.env` when you are ready to use the
# ReSpeaker Lite USB microphone on the Raspberry Pi host.

SATELLITE_NAME=respeaker-lite
SATELLITE_URI=tcp://0.0.0.0:10700

# Path where the official wyoming-satellite repository is installed on the Pi host.
WYOMING_SATELLITE_DIR=/opt/wyoming-satellite

# openWakeWord is optional, but recommended for hands-free usage.
WAKE_URI=tcp://127.0.0.1:10400
WAKE_WORD_NAME=ok_nabu

# Device hints are matched case-insensitively against `arecord -L` / `aplay -L`.
# The wrapper prefers `plughw:` devices, per the official wyoming-satellite docs.
MIC_DEVICE_HINT=ReSpeaker Lite
SND_DEVICE_HINT=ReSpeaker Lite

# Audio processing. These mirror Wyoming satellite settings documented by Home Assistant.
MIC_AUTO_GAIN=5
MIC_NOISE_SUPPRESSION=2
MIC_VOLUME_MULTIPLIER=1.0
SND_VOLUME_MULTIPLIER=1.0

# Startup behavior
SATELLITE_WAIT_FOR_DEVICE_SECONDS=5
SATELLITE_DEBUG=0
