HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=replace-with-long-lived-access-token
INTERPRETER_MODE=claude_cli
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLAUDE_CLI_COMMAND=claude
CLAUDE_CLI_CWD=/app
CLAUDE_CLI_HOME=/home/claude-host-home
CLAUDE_CLI_TIMEOUT_SECONDS=45
CLAUDE_CLI_DISABLE_AUTO_MEMORY=1
CLAUDE_CLI_MAX_PROMPT_TARGETS=12
CLAUDE_CLI_MAX_VISIBLE_STATES=8
FAST_PATH_LOCAL_FIRST=1
LOCAL_TIMEZONE=America/Argentina/Buenos_Aires
SCHEDULING_ENABLED=1
SCHEDULER_POLL_INTERVAL_SECONDS=1
SCHEDULER_DATA_DIR=/home/claude-host-home/ha-command-bridge-data
SCHEDULER_STORE_FILENAME=scheduled_commands.json
ROUTINES_ENABLED=1
ROUTINES_POLL_INTERVAL_SECONDS=30
ROUTINES_DATA_DIR=/home/claude-host-home/ha-command-bridge-data
ROUTINES_STORE_FILENAME=routines.json
SAVED_SCENES_ENABLED=1
SAVED_SCENES_DATA_DIR=/home/claude-host-home/ha-command-bridge-data
SAVED_SCENES_STORE_FILENAME=saved_scenes.json
STATE_MEMORY_ENABLED=1
STATE_MEMORY_DATA_DIR=/home/claude-host-home/ha-command-bridge-data
STATE_MEMORY_STORE_FILENAME=previous_state_cache.json
# Keep this enabled while exploring a new Home Assistant instance.
# For a polished fixed install, prefer AUTO_DISCOVER_ENTITIES=0 and use VOICE_MODEL_FILE.
AUTO_DISCOVER_ENTITIES=1
AUTO_DISCOVER_DOMAINS=light,switch,lock,cover,fan,climate,media_player,vacuum,sensor,binary_sensor
AUTO_DISCOVER_INCLUDE_UNAVAILABLE=0
IGNORED_ENTITIES=
ALLOWED_ENTITIES=
ALLOWED_SCENES=scene.movie_time,scene.good_night
ALLOWED_SCRIPTS=script.prepare_bedtime,script.turn_off_downstairs
# Recommended for a stable voice installation: point this at a curated file
# that exists on the Raspberry Pi host and is visible inside the container.
VOICE_MODEL_FILE=/home/claude-host-home/ha-command-bridge/voice_model.json
# Keep this empty unless you need a quick override without editing the file above.
TARGET_OVERRIDES_JSON={}
REQUEST_TIMEOUT_SECONDS=20
AUDIO_RESPONSE_ENABLED=0
AUDIO_RESPONSE_ENGINE=kokoro
AUDIO_RESPONSE_VOICE=en-us
AUDIO_RESPONSE_SPEED=155
AUDIO_RESPONSE_DEVICE=plughw:0,0
AUDIO_RESPONSE_CACHE_ENABLED=1
AUDIO_RESPONSE_CACHE_DIR=/home/claude-host-home/ha-command-bridge-data/audio-cache
AUDIO_RESPONSE_FAST_ACK_FOR_LOCAL=0
AUDIO_RESPONSE_FAST_ACK_TEXT=Done.
KOKORO_MODEL_PATH=/home/claude-host-home/ha-command-bridge-data/kokoro/kokoro-v1.0.int8.onnx
KOKORO_VOICES_PATH=/home/claude-host-home/ha-command-bridge-data/kokoro/voices-v1.0.bin
KOKORO_VOICE=af_heart
KOKORO_LANG=en-us
KOKORO_SPEED=1.0
KOKORO_SAMPLE_RATE=24000
KOKORO_WARMUP_ENABLED=1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.8
ELEVENLABS_STYLE=0.1
ELEVENLABS_USE_SPEAKER_BOOST=1
ELEVENLABS_SPEED=1.0
PIPER_COMMAND=piper
PIPER_MODEL_PATH=/home/claude-host-home/ha-command-bridge-data/piper/en_US-lessac-medium.onnx
PIPER_SPEAKER=0
PIPER_LENGTH_SCALE=1.0
LOG_LEVEL=INFO
