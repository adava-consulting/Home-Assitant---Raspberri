bridge_test() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: ./scripts/pi bridge-test \"<text>\" [--execute]" >&2
    exit 1
  fi
  local dry_run=true
  local text="$1"
  local source="pi_bridge_test"
  if [[ "${2:-}" == "--execute" ]]; then
    dry_run=false
  fi
  local json_payload
  json_payload="$(printf '{"text":"%s","dry_run":%s,"source":"%s"}' "$(printf '%s' "$text" | sed 's/"/\\"/g')" "$dry_run" "$source")"
  run_ssh_expect "curl -s -X POST http://127.0.0.1:8000/commands/interpret -H 'Content-Type: application/json' -d '$json_payload'"
}

lights_phrase() {
  local target="$1"
  local action="$2"
  case "$target" in
    room)
      printf 'turn the room lights %s' "$action"
      ;;
    studio)
      printf 'turn the studio lights %s' "$action"
      ;;
    all)
      printf 'turn all lights %s' "$action"
      ;;
    *)
      echo "Unsupported lights target: ${target}" >&2
      exit 1
      ;;
  esac
}

light_history() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: ./scripts/pi light-history <room|studio|light.entity_id> [--hours <N>]" >&2
    exit 1
  fi

  local target="$1"
  shift
  local hours=24

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --hours)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for --hours" >&2
          exit 1
        fi
        if ! [[ "$2" =~ ^[0-9]+$ ]]; then
          echo "Unsupported --hours value '${2}'. Use an integer like 6, 12, or 24." >&2
          exit 1
        fi
        hours="$2"
        shift 2
        ;;
      *)
        echo "Unexpected argument: $1" >&2
        exit 1
        ;;
    esac
  done

  run_ssh_expect "cd '${PI_REMOTE_BRIDGE_DIR}' && set -a && . ./.env && set +a && python3 - '$(printf '%s' "$target")' '${hours}' <<'PY'
import datetime as dt
import json
import os
import sys
import urllib.parse
import urllib.request


def fetch_json(url: str, headers: dict[str, str]):
    req = urllib.request.Request(url, headers=headers)
    with urllib.request.urlopen(req, timeout=20) as response:
        return json.load(response)


target_arg = sys.argv[1].strip()
hours = int(sys.argv[2])
alias_map = {
    'room': 'light.room',
    'studio': 'light.studio',
}
target_entity = alias_map.get(target_arg, target_arg)

base_url = os.environ['HOME_ASSISTANT_URL'].rstrip('/')
headers = {
    'Authorization': f\"Bearer {os.environ['HOME_ASSISTANT_TOKEN']}\",
    'Content-Type': 'application/json',
}

states = fetch_json(f\"{base_url}/api/states\", headers)
states_by_entity_id = {
    state.get('entity_id'): state
    for state in states
    if isinstance(state.get('entity_id'), str)
}

targets: list[str] = []
if target_entity:
    targets.append(target_entity)

target_state = states_by_entity_id.get(target_entity)
member_entity_ids = []
if isinstance(target_state, dict):
    members = target_state.get('attributes', {}).get('entity_id')
    if isinstance(members, list):
        member_entity_ids = [
            member
            for member in members
            if isinstance(member, str) and member.startswith('light.')
        ]
        targets.extend(member_entity_ids)

seen = set()
unique_targets = []
for entity_id in targets:
    if entity_id in seen:
        continue
    seen.add(entity_id)
    unique_targets.append(entity_id)

now = dt.datetime.now(dt.UTC)
start = now - dt.timedelta(hours=hours)
start_text = start.isoformat()
end_text = now.isoformat()

print('== target ==')
if isinstance(target_state, dict):
    print(
        f\"{target_entity}: state={target_state.get('state')} \"
        f\"friendly_name={target_state.get('attributes', {}).get('friendly_name')!r}\"
    )
else:
    print(f\"{target_entity}: current state not found in /api/states\")

if member_entity_ids:
    print(f\"members={member_entity_ids}\")

print()
print(f'== Home Assistant logbook ({hours}h) ==')
for entity_id in unique_targets:
    params = urllib.parse.urlencode(
        {
            'entity': entity_id,
            'end_time': end_text,
        }
    )
    url = f\"{base_url}/api/logbook/{urllib.parse.quote(start_text, safe='')}?{params}\"
    try:
        entries = fetch_json(url, headers)
    except Exception as exc:
        print(f\"{entity_id}: failed to fetch logbook: {exc}\")
        print()
        continue

    if not isinstance(entries, list):
        print(f\"{entity_id}: unexpected logbook payload\")
        print()
        continue

    entries = sorted(entries, key=lambda item: str(item.get('when', '')))
    recent_entries = entries[-20:]

    print(f\"-- {entity_id} ({len(entries)} entr{'y' if len(entries) == 1 else 'ies'}) --\")
    if not recent_entries:
        print('  no logbook entries in this window')
        print()
        continue

    for entry in recent_entries:
        when = entry.get('when', '-')
        name = entry.get('name', '-')
        message = entry.get('message', '-')
        domain = entry.get('domain', '-')
        context_user_id = entry.get('context_user_id') or '-'
        print(
            f\"  {when} | name={name} | message={message} | domain={domain} | user={context_user_id}\"
        )
    print()
PY"
}

if [[ $# -lt 1 ]]; then
  show_help
  exit 1
fi

subcommand="$1"
shift

case "$subcommand" in
  help|-h|--help)
    show_help
    ;;

  status)
    run_ssh_expect "hostname && hostname -I && echo && docker ps --format 'table {{.Names}}\t{{.Status}}'"
    printf '\n'
    run_ssh_expect_with_sudo "systemctl status wyoming-satellite.service --no-pager"
    printf '\n'
    run_ssh_expect "cd '${PI_REMOTE_BRIDGE_DIR}' && grep '^VOICE_MODEL_FILE=' .env || true"
    ;;

  doctor)
    run_ssh_expect "hostname && hostname -I && echo && uptime && echo && free -h && echo && docker ps --format 'table {{.Names}}\t{{.Status}}'"
    printf '\n'
    run_ssh_expect_with_sudo "systemctl status wyoming-satellite.service --no-pager"
    printf '\n'
    run_ssh_expect "cd '${PI_REMOTE_BRIDGE_DIR}' && grep '^VOICE_MODEL_FILE=' .env || true"
    printf '\n'
    bridge_test "turn the room lights off"
    ;;

  wake-debug)
    parse_recent_window_args "$@"
    recent_window_desc="$(recent_window_description)"
    run_ssh_expect "echo '== containers ==' && docker ps --format 'table {{.Names}}\\t{{.Status}}\\t{{.Ports}}'"
    printf '\n'
    run_ssh_expect_with_sudo "echo '== wyoming satellite ==' && systemctl status wyoming-satellite.service --no-pager -l && echo && echo '== listening ports ==' && ss -ltn | egrep '10200|10300|10400|10700' || true"
    printf '\n'
    run_ssh_expect "echo '== bridge env ==' && cd '${PI_REMOTE_BRIDGE_DIR}' && grep -E '^(INTERPRETER_MODE|FAST_PATH_LOCAL_FIRST|AUTO_DISCOVER_ENTITIES|AUTO_DISCOVER_INCLUDE_UNAVAILABLE|AUDIO_RESPONSE_ENABLED|VOICE_MODEL_FILE|ASSIST_GUARD_ENABLED|ASSIST_GUARD_RECENT_WAKE_WINDOW_SECONDS|ACTIVITY_LOG_MAX_ENTRIES|MONITOR_CONTROL_ENABLED|MONITOR_CONTROL_SSH_HOST|MONITOR_CONTROL_REMOTE_SCRIPT_PATH)=' .env || true && echo && echo '== voice services env ==' && if [ -f '${PI_REMOTE_BRIDGE_DIR}/voice_services/.env' ]; then grep -E '^(WAKE_WORD_MODEL|WAKE_WORD_THRESHOLD|WAKE_WORD_TRIGGER_LEVEL|WAKE_WORD_REFRACTORY_SECONDS|WHISPER_MODEL|WHISPER_LANGUAGE|WHISPER_BEAM_SIZE|WHISPER_VAD_MIN_SPEECH_MS|WHISPER_VAD_MIN_SILENCE_MS)=' '${PI_REMOTE_BRIDGE_DIR}/voice_services/.env'; else echo 'voice_services/.env missing'; fi && echo && echo '== satellite env ==' && if [ -f '${PI_REMOTE_BRIDGE_DIR}/voice_services/respeaker_lite_satellite.env' ]; then grep -E '^(MIC_CAPTURE_CHANNELS|MIC_CHANNEL_INDEX|WAKE_REFRACTORY_SECONDS|WAKE_SERVICE_READY_TIMEOUT_SECONDS|WAKE_SERVICE_READY_CHECK_INTERVAL_SECONDS|MIC_SECONDS_TO_MUTE_AFTER_AWAKE_WAV|SND_VOLUME_MULTIPLIER|SND_MIXER_CARD|SND_MIXER_CONTROL|SND_MIXER_LEVEL|SATELLITE_STREAMING_TIMEOUT_SECONDS|SATELLITE_NO_SPEECH_TIMEOUT_SECONDS|SATELLITE_TRANSCRIPT_TIMEOUT_SECONDS|SATELLITE_POST_TRANSCRIPT_COOLDOWN_SECONDS|SATELLITE_FORCE_ASSIST_IDLE_ON_RECOVERY|SATELLITE_AWAKE_WAV)=' '${PI_REMOTE_BRIDGE_DIR}/voice_services/respeaker_lite_satellite.env'; else echo 'respeaker_lite_satellite.env missing'; fi"
    printf '\n'
    wake_debug_summary "${recent_window_desc}"
    printf '\n'
    run_ssh_expect_with_sudo "echo '== satellite journal (${recent_window_desc}) ==' && $(journalctl_recent_command 'wyoming-satellite.service' 120) | egrep 'Detection\\(|Event\\(type=.transcript|Event\\(type=.synthesize|Event\\(type=.error|No speech detected|Transcript not received|stt-no-text-recognized|Waiting for wake word|Connected to server|Connected to wake service|Connected to mic service' || true"
    printf '\n'
    run_ssh_expect "echo '== openwakeword logs (${recent_window_desc}) ==' && $(docker_logs_recent_command 'wyoming-openwakeword' 80) 2>&1 || true && echo && echo '== whisper logs (${recent_window_desc}) ==' && $(docker_logs_recent_command 'wyoming-whisper' 80) 2>&1 || true && echo && echo '== bridge logs (${recent_window_desc}) ==' && $(docker_logs_recent_command 'ha-command-bridge' 80) 2>&1 | egrep -i 'assist|interpret|input text|executed:|fast path|local interpreter|error|traceback|turn on|turn off|all lights|room|studio|monitor' || true"
    ;;

