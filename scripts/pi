#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_FILE="${PI_CONFIG_FILE:-${PROJECT_DIR}/.pi.env}"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

: "${PI_HOST:=192.168.0.17}"
: "${PI_USER:=lucas}"
: "${PI_PASSWORD:=}"
: "${PI_REMOTE_BRIDGE_DIR:=/home/lucas/ha-command-bridge}"
: "${PI_REMOTE_BRIDGE_DATA_DIR:=/home/lucas/ha-command-bridge-data}"
: "${PI_REMOTE_BOOTSTRAP_DIR:=/home/lucas/homeassistant-bootstrap}"
: "${PI_LOG_SINCE_DEFAULT:=30m}"
: "${PI_DEBUG_RECORDING_DIR:=/tmp/wyoming-debug}"
: "${PI_DEBUG_RECORDING_CLEAN_DEFAULT:=24h}"

escape_single_quotes() {
  printf "%s" "$1" | sed "s/'/'\"'\"'/g"
}

need_password() {
  if [[ -z "${PI_PASSWORD}" ]]; then
    echo "PI_PASSWORD is empty. Create ${CONFIG_FILE} from .pi.env.example." >&2
    exit 1
  fi
}

run_ssh_expect() {
  need_password
  expect "${PROJECT_DIR}/scripts/ssh_command.expect" \
    "${PI_PASSWORD}" \
    "${PI_HOST}" \
    "$1"
}

run_ssh_expect_with_sudo() {
  need_password
  local escaped_password
  escaped_password="$(escape_single_quotes "${PI_PASSWORD}")"
  local command="$1"
  run_ssh_expect "printf '%s\n' '${escaped_password}' | sudo -S -p '' bash -lc '$(escape_single_quotes "$command")'"
}

validate_duration_token() {
  local value="$1"
  if ! [[ "$value" =~ ^[0-9]+[smhd]$ ]]; then
    echo "Unsupported duration '${value}'. Use values like 30m, 2h, or 1d." >&2
    exit 1
  fi
}

journal_since_expr() {
  local value="$1"
  if [[ "$value" =~ ^([0-9]+)([smhd])$ ]]; then
    local amount="${BASH_REMATCH[1]}"
    local unit="${BASH_REMATCH[2]}"
    case "$unit" in
      s) printf '%s seconds ago' "$amount" ;;
      m) printf '%s minutes ago' "$amount" ;;
      h) printf '%s hours ago' "$amount" ;;
      d) printf '%s days ago' "$amount" ;;
    esac
    return 0
  fi

  printf '%s' "$value"
}

duration_to_find_minutes() {
  local value="$1"
  if ! [[ "$value" =~ ^([0-9]+)([smhd])$ ]]; then
    echo "Unsupported duration '${value}'. Use values like 30m, 2h, or 1d." >&2
    exit 1
  fi

  local amount="${BASH_REMATCH[1]}"
  local unit="${BASH_REMATCH[2]}"
  local minutes=0
  case "$unit" in
    s) minutes=$(( (amount + 59) / 60 )) ;;
    m) minutes=$amount ;;
    h) minutes=$(( amount * 60 )) ;;
    d) minutes=$(( amount * 1440 )) ;;
  esac

  if (( minutes < 1 )); then
    minutes=1
  fi

  printf '%s' "$minutes"
}

parse_recent_window_args() {
  RECENT_WINDOW_MODE="since"
  RECENT_WINDOW_SINCE="$PI_LOG_SINCE_DEFAULT"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all)
        RECENT_WINDOW_MODE="all"
        shift
        ;;
      --since)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for --since" >&2
          exit 1
        fi
        validate_duration_token "$2"
        RECENT_WINDOW_SINCE="$2"
        RECENT_WINDOW_MODE="since"
        shift 2
        ;;
      *)
        echo "Unexpected argument: $1" >&2
        exit 1
        ;;
    esac
  done
}

recent_window_description() {
  if [[ "${RECENT_WINDOW_MODE}" == "all" ]]; then
    printf 'all available history'
    return 0
  fi

  printf 'last %s' "${RECENT_WINDOW_SINCE}"
}

docker_logs_recent_command() {
  local container="$1"
  local tail_count="$2"
  local command="docker logs --tail ${tail_count}"
  if [[ "${RECENT_WINDOW_MODE}" == "since" ]]; then
    command+=" --since ${RECENT_WINDOW_SINCE}"
  fi
  command+=" ${container}"
  printf '%s' "$command"
}

journalctl_recent_command() {
  local unit="$1"
  local tail_count="$2"
  if [[ "${RECENT_WINDOW_MODE}" == "since" ]]; then
    local journal_since
    journal_since="$(journal_since_expr "${RECENT_WINDOW_SINCE}")"
    printf 'journalctl -u %s --since "%s" -n %s --no-pager' "$unit" "$journal_since" "$tail_count"
    return 0
  fi

  printf 'journalctl -u %s -n %s --no-pager' "$unit" "$tail_count"
}

wake_debug_summary() {
  local recent_window_desc="$1"
  local journal_cmd
  local openwakeword_logs_cmd
  local whisper_logs_cmd
  local summary_cmd

  journal_cmd="$(journalctl_recent_command 'wyoming-satellite.service' 200)"
  openwakeword_logs_cmd="$(docker_logs_recent_command 'wyoming-openwakeword' 120)"
  whisper_logs_cmd="$(docker_logs_recent_command 'wyoming-whisper' 120)"

  summary_cmd="$(cat <<EOF
tmp_dir=\$(mktemp -d)
cleanup() { rm -rf "\$tmp_dir"; }
trap cleanup EXIT
${journal_cmd} >"\$tmp_dir/satellite.log" 2>&1 || true
${openwakeword_logs_cmd} >"\$tmp_dir/openwakeword.log" 2>&1 || true
${whisper_logs_cmd} >"\$tmp_dir/whisper.log" 2>&1 || true
curl -fsS 'http://127.0.0.1:8000/activity?limit=40' >"\$tmp_dir/activity.json" 2>/dev/null || printf '%s\n' '{"count":0,"entries":[]}' >"\$tmp_dir/activity.json"
curl -fsS 'http://127.0.0.1:8000/assist-guard' >"\$tmp_dir/assist_guard.json" 2>/dev/null || printf '%s\n' '{"enabled":false,"state":{}}' >"\$tmp_dir/assist_guard.json"
python3 - "\$tmp_dir" "${recent_window_desc}" <<'PY'
from __future__ import annotations

import json
from pathlib import Path
import re
import sys
import time

root = Path(sys.argv[1])
recent_window_desc = sys.argv[2]


def read_text(name: str) -> str:
    path = root / name
    try:
        return path.read_text("utf-8", errors="replace")
    except FileNotFoundError:
        return ""


def read_json(name: str, fallback: dict) -> dict:
    path = root / name
    try:
        payload = json.loads(path.read_text("utf-8", errors="replace"))
    except Exception:
        return dict(fallback)
    return payload if isinstance(payload, dict) else dict(fallback)


def count(pattern: str, text: str, *, flags: int = 0) -> int:
    return len(re.findall(pattern, text, flags))


def truncate(value: str, limit: int = 80) -> str:
    compact = " ".join(str(value).split())
    if len(compact) <= limit:
        return compact
    return compact[: limit - 3] + "..."


def age_seconds(timestamp_ms: object, *, now_ms: int) -> str:
    try:
        timestamp_ms = int(timestamp_ms)
    except (TypeError, ValueError):
        return "none"
    if timestamp_ms <= 0:
        return "none"
    age_ms = max(0, now_ms - timestamp_ms)
    return f"{age_ms / 1000:.1f}"


satellite_log = read_text("satellite.log")
openwakeword_log = read_text("openwakeword.log")
whisper_log = read_text("whisper.log")
combined_logs = "\n".join([satellite_log, openwakeword_log, whisper_log])

activity_payload = read_json("activity.json", {"count": 0, "entries": []})
assist_guard_payload = read_json("assist_guard.json", {"enabled": False, "state": {}})

activity_entries = activity_payload.get("entries")
if not isinstance(activity_entries, list):
    activity_entries = []

assist_entries = [
    entry
    for entry in activity_entries
    if isinstance(entry, dict) and str(entry.get("source", "")).startswith("assist_")
]
assist_failed_entries = [entry for entry in assist_entries if entry.get("status") == "failed"]
guard_failures = [
    entry
    for entry in assist_failed_entries
    if isinstance(entry.get("details"), dict) and entry["details"].get("guard") == "assist_recent_wake"
]
last_assist_entry = assist_entries[0] if assist_entries else None
last_assist_error = None
if assist_failed_entries:
    details = assist_failed_entries[0].get("details")
    if isinstance(details, dict):
        last_assist_error = details.get("error")

assist_guard_state = assist_guard_payload.get("state")
if not isinstance(assist_guard_state, dict):
    assist_guard_state = {}

now_ms = int(time.time() * 1000)
detections = count(r"Detection\(", satellite_log)
transcripts = count(r"Event\(type=.transcript", satellite_log)
syntheses = count(r"Event\(type=.synthesize", satellite_log)
satellite_errors = count(r"Event\(type=.error", satellite_log)
no_speech_restarts = count(r"No speech detected", satellite_log)
transcript_timeouts = count(r"Transcript not received", satellite_log)
stt_no_text = count(r"stt-no-text-recognized", combined_logs)
bridge_assist_entries = len(assist_entries)
bridge_assist_executed = sum(1 for entry in assist_entries if entry.get("status") == "executed")
bridge_assist_failed = len(assist_failed_entries)
assist_guard_failures = len(guard_failures)

print(f"== wake-debug summary ({recent_window_desc}) ==")
print(
    "wake_counts:"
    f" detections={detections}"
    f" transcripts={transcripts}"
    f" synthesize={syntheses}"
    f" satellite_errors={satellite_errors}"
)
print(
    "recovery_counts:"
    f" no_speech_restarts={no_speech_restarts}"
    f" transcript_timeouts={transcript_timeouts}"
    f" stt_no_text={stt_no_text}"
)
print(
    "bridge_counts:"
    f" assist_entries={bridge_assist_entries}"
    f" assist_executed={bridge_assist_executed}"
    f" assist_failed={bridge_assist_failed}"
    f" assist_guard_failures={assist_guard_failures}"
)
print(
    "assist_guard:"
    f" enabled={bool(assist_guard_payload.get('enabled'))}"
    f" last_detection_age_s={age_seconds(assist_guard_state.get('last_detection_ms'), now_ms=now_ms)}"
    f" last_consumed_age_s={age_seconds(assist_guard_state.get('last_consumed_detection_ms'), now_ms=now_ms)}"
)

if last_assist_entry is not None:
    print(
        "last_assist:"
        f" status={last_assist_entry.get('status', 'unknown')}"
        f" source={last_assist_entry.get('source', 'unknown')}"
        f" text={truncate(last_assist_entry.get('text', ''))!r}"
    )
if last_assist_error:
    print(f"last_assist_error: {truncate(last_assist_error, limit=140)}")

print()
print("Likely breakpoint:")
if detections == 0:
    print(
        "- No wake detections were observed in the selected window. "
        "If the failed attempt is inside this window, focus on openWakeWord sensitivity or the mic path."
    )
elif transcripts == 0:
    if no_speech_restarts > 0:
        print(
            "- Wake was detected, but the satellite restarted for no-speech before any transcript arrived. "
            "This points to the wake-to-stream handoff or the command start being missed."
        )
    elif stt_no_text > 0:
        print(
            "- Wake appears to have reached STT, but Whisper returned no usable text."
        )
    else:
        print(
            "- Wake was detected, but no transcript reached the bridge. "
            "Check the satellite and Whisper handoff."
        )
elif bridge_assist_entries == 0:
    print(
        "- Transcripts were observed, but no recent Assist activity reached the bridge. "
        "Check the Home Assistant Assist pipeline routing."
    )
elif bridge_assist_executed > 0:
    print(
        "- The selected window includes at least one successful end-to-end Assist execution."
    )
elif assist_guard_failures > 0:
    print(
        "- Assist reached the bridge, but the recent command was rejected by the recent-wake guard."
    )
elif bridge_assist_failed > 0:
    print(
        "- Assist reached the bridge, but the recent command failed before execution."
    )
else:
    print(
        "- The raw logs do not point to one obvious breakpoint yet. Check the detailed sections below."
    )
PY
EOF
)"

  run_ssh_expect_with_sudo "$summary_cmd"
}

parse_debug_clean_args() {
  DEBUG_CLEAN_MODE="older-than"
  DEBUG_CLEAN_AGE="$PI_DEBUG_RECORDING_CLEAN_DEFAULT"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all)
        DEBUG_CLEAN_MODE="all"
        shift
        ;;
      --older-than)
        if [[ $# -lt 2 ]]; then
          echo "Missing value for --older-than" >&2
          exit 1
        fi
        validate_duration_token "$2"
        DEBUG_CLEAN_AGE="$2"
        DEBUG_CLEAN_MODE="older-than"
        shift 2
        ;;
      *)
        echo "Unexpected argument: $1" >&2
        exit 1
        ;;
    esac
  done
}

