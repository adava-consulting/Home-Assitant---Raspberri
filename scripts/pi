  cat <<'EOF'
Usage:
  ./scripts/pi help
  ./scripts/pi status
  ./scripts/pi doctor
  ./scripts/pi wake-debug [--since <30m|2h|1d>|--all]
  ./scripts/pi ghost-check
  ./scripts/pi voice-check [--since <30m|2h|1d>|--all]
  ./scripts/pi lights-check
  ./scripts/pi light-history <room|studio|light.entity_id> [--hours <N>]
  ./scripts/pi monitor <on|off|status>
  ./scripts/pi wake-tune
  ./scripts/pi shortcuts-install
  ./scripts/pi bridge-audio <on|off>
  ./scripts/pi single-voice
  ./scripts/pi satellite-channel <auto|0|1>
  ./scripts/pi cmd "<remote command>"
  ./scripts/pi logs <homeassistant|bridge|openwakeword|whisper|piper|satellite> [--since <30m|2h|1d>|--all]
  ./scripts/pi debug-clean [--older-than <30m|2h|1d>|--all]
  ./scripts/pi bridge-test "<text>" [--execute]
  ./scripts/pi lights <room|studio|all> <on|off> [--execute]
  ./scripts/pi room <on|off> [--execute]
  ./scripts/pi studio <on|off> [--execute]
  ./scripts/pi all <on|off> [--execute]
  ./scripts/pi deploy
  ./scripts/pi deploy-voice
  ./scripts/pi sync-ha
  ./scripts/pi redeploy
  ./scripts/pi fetch-debug
  ./scripts/pi satellite-fast
  ./scripts/pi ssh

Examples:
  ./scripts/pi help
  ./scripts/pi status
  ./scripts/pi doctor
  ./scripts/pi wake-debug
  ./scripts/pi wake-debug --all
  ./scripts/pi ghost-check
  ./scripts/pi voice-check
  ./scripts/pi logs satellite --since 2h
